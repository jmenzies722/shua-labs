{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadOnlyAgentAccess",
      "Effect": "Allow",
      "Action": [
        "ce:GetCostAndUsage",
        "ce:GetCostForecast",
        "budgets:DescribeBudgets",
        "budgets:ViewBudget",
